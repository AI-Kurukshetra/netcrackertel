{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@telecosync/types": [
        "packages/types/src"
      ],
      "@telecosync/database": [
        "packages/database/src"
      ],
      "@telecosync/api": [
        "packages/api/src"
      ],
      "@telecosync/services": [
        "packages/services/src"
      ],
      "@telecosync/ui": [
        "packages/ui/src"
      ]
    }
  }
}
